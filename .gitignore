models/
# models/**/predictions_*.csv
# models/**/metrics.json
# models/**/feature_metadata.json
# models/**/combined_standardized_training_rows.csv
# models/**/combined_modeling_rows_after_feature_merge.csv

# Candidate-screening outputs are generated and reproducible.
data/generated_candidates/
#data/processed/fluodb_lite/
outputs/candidate_screening/

# =========================
# Raw/private data
# =========================
# Keep private/raw local data out of GitHub unless intentionally sanitized.
#data/raw/
#chemfluor_data.csv

# =========================
# Large spreadsheet/raw source files
# =========================
*.xlsx
*.xls
*.xlsm

# =========================
# Optional: allow sanitized data files
# =========================
# If you want to commit a sanitized combined dataset, place it under:
# data/processed/
# and make sure it is not too large for GitHub.
!data/
!data/processed/
!data/processed/*.csv
!data/README.md
# Local development notes
#development md/
